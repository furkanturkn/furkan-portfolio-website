# pinqloq client logging (server-side forward leg).
# Copy to .env.local and fill in. NEVER commit real secrets.
#
# The raw pinqloq HTTP ingest URL is not documented yet (the SDK docs cover the
# .NET SDK only). Until PINQLOQ_INGEST_URL + PINQLOQ_SECRET_KEY are set, the
# /api/logs route validates events and logs them to the server console instead
# of shipping them to pinqloq. Set both to enable real forwarding.

# pinqloq log ingest endpoint (the URL /api/logs POSTs the entry to).
PINQLOQ_INGEST_URL=

# Server credential, sent as the X-Secret-Key header. Keep it server-side only.
PINQLOQ_SECRET_KEY=

# Collection for forwarded client (Device-source) logs.
PINQLOQ_CLIENT_COLLECTION=client_logs

# Optional version label attached to client logs (exposed to the browser).
NEXT_PUBLIC_APP_VERSION=1.0.0
